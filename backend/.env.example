# Server Configuration
SPRING_PROFILES_ACTIVE=dev

# Database Configuration (Prod Profile)
DB_URL=jdbc:postgresql://localhost:5432/bnytech
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Authentication
JWT_SECRET=generate_a_secure_base64_secret_key_that_is_at_least_32_bytes_long_like_a_random_sha256_hash

# Security
ALLOWED_ORIGINS=http://localhost:3000,https://bnytechnologies.com

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@bnytechnologies.com
SMTP_PASSWORD=your_app_password
